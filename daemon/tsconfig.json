{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "..",
    "noEmit": false,
    "sourceMap": true,
    "declaration": false,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*.ts",
    "../src/messageSender.ts",
    "../src/terminalRegistry.ts",
    "../src/agentRuntime.ts",
    "../src/types.ts",
    "../src/timerManager.ts",
    "../src/transcriptParser.ts"
  ],
  "exclude": ["node_modules", "dist", "src/hooks"]
}
