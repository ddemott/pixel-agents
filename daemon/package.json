{
  "name": "pixel-agents-daemon",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/daemon/src/server.js",
  "bin": {
    "pixel-agents-daemon": "dist/daemon/src/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').writeFileSync('dist/src/package.json', JSON.stringify({type:'commonjs'}))\"",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/daemon/src/server.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.1"
  }
}
